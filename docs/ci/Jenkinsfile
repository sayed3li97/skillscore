// Jenkins: gate skill quality inside a Dart container.
// Requires the Docker Pipeline plugin. Copy into a Jenkinsfile at your repo root.
pipeline {
  agent {
    docker { image 'dart:stable' }
  }
  stages {
    stage('Install skillscore') {
      steps {
        sh 'dart pub global activate skillscore'
      }
    }
    stage('Score and gate') {
      steps {
        sh '''
          export PATH="$HOME/.pub-cache/bin:$PATH"
          skillscore skills/ --min-score 80 --no-color
        '''
      }
    }
  }
  post {
    always {
      sh '''
        export PATH="$HOME/.pub-cache/bin:$PATH"
        skillscore skills/ --format json --no-color > skillscore.json || true
      '''
      archiveArtifacts artifacts: 'skillscore.json', allowEmptyArchive: true
    }
  }
}
